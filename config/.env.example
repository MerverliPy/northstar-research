# === Local development (127.0.0.1 only) ===
# HOST=127.0.0.1

# === Tailscale / remote access ===
HOST=0.0.0.0

# Each service has its own port (defaults shown):
#   research-agent:     8099
#   research-portal:    3010
#   chat-import-bridge: 3022
# Override per-service in apps/<name>/.env

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://northstar:northstar@127.0.0.1:5432/northstar

# Neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=northstar

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
PRIMARY_LLM_MODEL=qwen3:14b
FALLBACK_LLM_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text

# ChromaDB
CHROMA_PERSIST_DIR=~/.cache/northstar/chromadb

# Safety gates
FORCE_GRAPH_EXTRACTION=false
ENABLE_DESTRUCTIVE_CLEANUP=false

LOG_LEVEL=INFO
