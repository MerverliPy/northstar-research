# Service hosts/ports
RESEARCH_AGENT_HOST=127.0.0.1
RESEARCH_AGENT_PORT=8099
RESEARCH_PORTAL_HOST=127.0.0.1
RESEARCH_PORTAL_PORT=3010
CHAT_IMPORT_BRIDGE_HOST=127.0.0.1
CHAT_IMPORT_BRIDGE_PORT=3022

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=northstar
POSTGRES_USER=northstar
POSTGRES_PASSWORD=northstar
DATABASE_URL=postgresql+asyncpg://northstar:northstar@127.0.0.1:5432/northstar

# Neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=northstar

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
PRIMARY_LLM_MODEL=qwen3:14b
FALLBACK_LLM_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text

# ChromaDB (file-backed, no Docker)
CHROMA_PERSIST_DIR=~/.cache/northstar/chromadb

# Safety flags (read-only defaults)
FORCE_GRAPH_EXTRACTION=false
ENABLE_DESTRUCTIVE_CLEANUP=false

# Logging
LOG_LEVEL=INFO
