{
  "$schema": "https://opencode.ai/config.json",
  "provider": {},
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "allow",
      "git push *": "ask",
      "docker compose down -v": "ask",
      "rm -rf *": "ask",
      "DROP *": "ask",
      "DELETE FROM *": "ask"
    },
    "todowrite": "allow",
    "webfetch": "allow"
  },
  "tools": {},
  "instructions": [
    "CONTRIBUTING.md",
    "ROOT_STRUCTURE.md",
    "docs/ARCHITECTURE.md",
    "docs/API.md"
  ]
}
